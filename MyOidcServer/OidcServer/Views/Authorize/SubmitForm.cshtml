@model CodeFlowResponseViewModel

<form method="post" action="@Model.RedirectUri" id="autoForm">
    <input type="hidden" name="code" value="@Model.Code" />
    <input type="hidden" name="state" value="@Model.State" />
</form>

<div class="container text-center mt-5">
    <h4>Redirecting...</h4>
    <p class="text-muted">You are being redirected back to the client application.</p>
</div>

<script>
    document.getElementById('autoForm').submit();
</script>